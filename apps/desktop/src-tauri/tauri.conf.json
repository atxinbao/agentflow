{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentFlow",
  "version": "1.2.6",
  "identifier": "com.agentflow.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AgentFlow",
        "width": 1280,
        "height": 820,
        "minWidth": 1040,
        "minHeight": 680,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": []
  }
}
