  ],
  "acceptanceSemantics": [
    {
      "acceptanceId": "software-dev.issue.done",
      "objectType": "Issue",
      "description": "任务完成必须有本地验证证据、PR/MR 记录和 Done 写回。",
      "requiredEvidence": [
        "validation",
        "pull-request",
        "completion-commit"
      ]
    }
  ],
  "evidencePolicy": {
    "policyId": "software-dev.evidence.required",
    "requiredEvidenceKinds": [
      "validation",
      "delivery"
    ],
    "missingEvidenceBehavior": "reject-completion"
  },
  "auditTriggerHints": [
    {
      "hintId": "software-dev.audit.sidecar",
      "objectType": "Release",
      "condition": "explicit-human-or-release-rule",
      "sidecarOnly": true
    }
  ],
  "migrationCompatibility": {
    "compatibleWithRuntime": ">=0.8.0",
    "migrationPolicyRef": "pack.migration.preview-only"
  },
  "writesEvents": false
}
