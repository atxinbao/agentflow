      "objectTypeId": "Spec",
      "label": "Spec",
      "description": "已确认规格"
    },
    {
      "objectTypeId": "Issue",
      "label": "Issue",
      "description": "可执行任务"
    },
    {
      "objectTypeId": "Run",
      "label": "Run",
      "description": "工作循环运行"
    },
    {
      "objectTypeId": "Acceptance",
      "label": "Acceptance",
      "description": "验收结论"
    },
    {
      "objectTypeId": "Delivery",
      "label": "Delivery",
      "description": "交付记录"
    },
    {
      "objectTypeId": "PullRequest",
      "label": "PullRequest",
      "description": "PR/MR 交付入口"
    },
    {
      "objectTypeId": "Release",
      "label": "Release",
      "description": "版本发布"
    },
    {
      "objectTypeId": "Evidence",
      "label": "Evidence",
      "description": "验证证据"
    },
    {
      "objectTypeId": "Audit",
      "label": "Audit",
      "description": "独立审计"
    },
    {
      "objectTypeId": "Finding",
      "label": "Finding",
      "description": "审计发现"
    },
    {
      "objectTypeId": "FollowUpProposal",
      "label": "FollowUpProposal",
      "description": "后续修复提案"
    }
  ],
  "linkTypes": [
    {
      "linkTypeId": "requirement-produces-spec",
      "fromObjectType": "Requirement",
      "toObjectType": "Spec",
      "description": "Requirement -> Spec"
    },
    {
      "linkTypeId": "spec-produces-issue",
      "fromObjectType": "Spec",
      "toObjectType": "Issue",
      "description": "Spec -> Issue"
    },
    {
      "linkTypeId": "issue-produces-run",
      "fromObjectType": "Issue",
      "toObjectType": "Run",
      "description": "Issue -> Run"
    },
    {
      "linkTypeId": "run-produces-acceptance",
      "fromObjectType": "Run",
      "toObjectType": "Acceptance",
      "description": "Run -> Acceptance"
    },
    {
      "linkTypeId": "acceptance-produces-delivery",
      "fromObjectType": "Acceptance",
      "toObjectType": "Delivery",
      "description": "Acceptance -> Delivery"
    },
    {
      "linkTypeId": "run-produces-evidence",
      "fromObjectType": "Run",
      "toObjectType": "Evidence",
      "description": "Run -> Evidence"
    },
    {
      "linkTypeId": "run-produces-pr",
      "fromObjectType": "Run",
      "toObjectType": "PullRequest",
      "description": "Run -> PullRequest"
    },
    {
      "linkTypeId": "delivery-includes-pr",
      "fromObjectType": "Delivery",
      "toObjectType": "PullRequest",
      "description": "Delivery -> PullRequest"
    },
    {
      "linkTypeId": "release-includes-delivery",
      "fromObjectType": "Release",
      "toObjectType": "Delivery",
      "description": "Release -> Delivery"
    },
    {
      "linkTypeId": "delivery-can-request-audit",
      "fromObjectType": "Delivery",
      "toObjectType": "Audit",
      "description": "Delivery -> Audit"
    },
    {
      "linkTypeId": "audit-produces-finding",
      "fromObjectType": "Audit",
      "toObjectType": "Finding",
      "description": "Audit -> Finding"
    },
    {
      "linkTypeId": "finding-produces-follow-up-proposal",
      "fromObjectType": "Finding",
      "toObjectType": "FollowUpProposal",
      "description": "Finding -> FollowUpProposal"
    }
  ],
  "stateMachines": [
    {
      "objectType": "Issue",
      "states": [
        "backlog",
        "todo",
        "in_progress",
        "in_review",
        "done",
        "blocked",
        "cancel"
      ],
      "transitions": [
        {
          "from": "backlog",
          "to": "todo",
          "actionType": "activateIssue"
        },
        {
          "from": "todo",
          "to": "in_progress",
          "actionType": "startRun"
        },
        {
          "from": "in_progress",
          "to": "in_review",
          "actionType": "runValidation"
        },
        {
          "from": "in_review",
          "to": "done",
          "actionType": "markIssueDone"
        }
      ]
    },
    {
      "objectType": "Audit",
      "states": [
        "requested",
        "in_progress",
        "reported",
        "closed"
      ],
      "transitions": [
        {
          "from": "requested",
          "to": "in_progress",
          "actionType": "requestAudit"
        },
        {
          "from": "in_progress",
          "to": "reported",
          "actionType": "createFinding"
        },
        {
          "from": "reported",
          "to": "closed",
          "actionType": "linkFixIssue"
        }
      ]
    }
  ],
  "actionSemantics": [
    {
      "actionType": "submitRequirement",
      "targetObjectType": "Requirement",
      "description": "submitRequirement on Requirement",
      "allowedRoles": [
        "WorkAgent"
      ],
      "contractRef": "action-contract:submitRequirement",
      "arbitrationRef": "action-arbitration:submitRequirement",
      "simulationRef": "simulation:submitRequirement",
      "requiredEvidence": [
        "validation"
      ]
    },
    {
      "actionType": "approveSpec",
      "targetObjectType": "Spec",
      "description": "approveSpec on Spec",
      "allowedRoles": [
        "WorkAgent"
