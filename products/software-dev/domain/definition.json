{
  "version": "agentflow-software-dev-domain.v1",
  "productId": "software-dev",
  "packId": "software-dev",
  "sourceBoundary": "products/software-dev/domain",
  "coreAuthority": false,
  "objectTypes": [
    {
      "type": "spec",
      "coreKind": "object",
      "description": "Confirmed requirement and implementation intent."
    },
    {
      "type": "task",
      "coreKind": "object",
      "description": "A Software Dev work item derived from confirmed Spec authority."
    },
    {
      "type": "run",
      "coreKind": "object",
      "description": "Runtime execution record for a task."
    },
    {
      "type": "pull-request",
      "coreKind": "external-proof",
      "description": "External review and merge record, not AgentFlow authority."
    },
    {
      "type": "release",
      "coreKind": "external-proof",
      "description": "Public delivery surface, not task authority by itself."
    }
  ],
  "states": [
    "backlog",
    "todo",
    "in_progress",
    "in_review",
    "done",
    "blocked",
    "cancel"
  ],
  "stateMachineObjectType": "task",
  "stateTransitions": [
    {
      "from": "todo",
      "to": "in_progress",
      "actionType": "startRun"
    },
    {
      "from": "in_progress",
      "to": "in_review",
      "actionType": "runValidation"
    },
    {
      "from": "in_review",
      "to": "done",
      "actionType": "markIssueDone"
    }
  ],
  "actions": [
    {
      "actionType": "startRun",
      "targetObjectType": "Issue",
      "description": "Start Software Dev task work through Runtime API.",
      "allowedRoles": [
        "build-agent"
      ],
      "contractRef": "action-contract:issue.start",
      "arbitrationRef": "action-arbitration:runtime-command",
      "simulationRef": "simulation:work.issue.start",
      "requiredEvidence": [
        "product-contract"
      ]
    },
    {
      "actionType": "prepareDelivery",
      "targetObjectType": "Run",
      "description": "Prepare review and delivery proof after local validation.",
      "allowedRoles": [
        "build-agent"
      ],
      "contractRef": "action-contract:delivery.prepare",
      "arbitrationRef": "action-arbitration:runtime-command",
      "simulationRef": "simulation:work.issue.review",
      "requiredEvidence": [
        "local-command-proof"
      ]
    }
  ],
  "acceptanceSemantics": [
    {
      "acceptanceId": "software-dev-acceptance",
      "objectType": "Run",
      "description": "Evidence and decision must be present before delivery.",
      "requiredEvidence": [
        "changed-content-proof",
        "local-command-proof",
        "merge-proof"
      ]
    }
  ],
  "evidencePolicy": {
    "policyId": "software-dev-product-evidence",
    "requiredEvidence": [
      "changed-content-proof",
      "local-command-proof",
      "merge-proof"
    ],
    "optionalEvidence": [
      "ui-proof",
      "provider-transcript",
      "audit-sidecar-proof"
    ],
    "insufficientAlone": [
      "pull-request",
      "release-note",
      "provider-transcript",
      "test-log"
    ]
  },
  "auditBoundary": {
    "defaultCompletionBlocker": false,
    "sidecarOnly": true
  }
}
